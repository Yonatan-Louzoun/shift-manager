<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ניהול משמרות Pro</title>
    
    <!-- פונט Rubik מגוגל פונטס -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- אייקונים של Lucide -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Rubik', 'sans-serif'],
                    },
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #f8fafc;
            -webkit-font-smoothing: antialiased;
        }
        
        .tab-btn {
            position: relative;
            transition: all 0.3s ease;
        }
        
        .tab-active {
            color: #2563eb;
            font-weight: 600;
        }
        
        .tab-active::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            right: 0;
            height: 3px;
            background-color: #3b82f6;
            border-radius: 3px 3px 0 0;
        }
        
        .tab-inactive {
            color: #64748b;
        }
        
        .tab-inactive:hover {
            color: #334155;
        }

        /* עיצוב פס גלילה */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9; 
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1; 
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8; 
        }

        .toast-enter {
            transform: translateY(100%);
            opacity: 0;
        }
        .toast-enter-active {
            transform: translateY(0);
            opacity: 1;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .toast-exit {
            transform: translateY(0);
            opacity: 1;
        }
        .toast-exit-active {
            transform: translateY(100%);
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>
</head>
<body class="text-slate-800">

    <div class="max-w-7xl mx-auto p-4 md:p-8">
        
        <!-- Header -->
        <header class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div class="flex items-center gap-4">
                <div class="bg-primary-50 p-3 rounded-xl text-primary-600">
                    <i data-lucide="calendar-clock" class="w-8 h-8"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-900">מערכת משמרות חכמה</h1>
                    <p class="text-slate-500 text-sm mt-1">ניהול שיבוצים מבוסס תאריכים</p>
                </div>
            </div>
            <button onclick="showClearDataModal()" class="flex items-center gap-2 text-sm text-red-600 hover:text-red-700 bg-red-50 hover:bg-red-100 px-4 py-2.5 rounded-xl transition font-medium">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
                איפוס מערכת
            </button>
        </header>

        <!-- Tabs Navigation -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 px-6 pt-4 mb-8 flex gap-8 border-b-2 overflow-x-auto">
            <button onclick="switchTab('constraints')" id="tab-constraints" class="tab-btn tab-active pb-4 px-2 text-lg flex items-center gap-2 whitespace-nowrap">
                <i data-lucide="user-x" class="w-5 h-5"></i>
                אילוצי עובדים
            </button>
            <button onclick="switchTab('schedule')" id="tab-schedule" class="tab-btn tab-inactive pb-4 px-2 text-lg flex items-center gap-2 whitespace-nowrap">
                <i data-lucide="table-2" class="w-5 h-5"></i>
                שיבוץ שבועי
            </button>
            <button onclick="switchTab('calendar')" id="tab-calendar" class="tab-btn tab-inactive pb-4 px-2 text-lg flex items-center gap-2 whitespace-nowrap">
                <i data-lucide="calendar-days" class="w-5 h-5"></i>
                לוח שנה חודשי
            </button>
        </div>

        <!-- תצוגה 1: אילוצים -->
        <section id="view-constraints" class="block animate-fade-in">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 md:p-8">
                
                <!-- Week Navigator & Employee Select -->
                <div class="flex flex-col lg:flex-row justify-between items-center mb-8 gap-6 bg-slate-50 p-4 rounded-xl border border-slate-100">
                    <div class="w-full lg:w-1/3">
                        <label class="block text-sm font-medium text-slate-700 mb-2">בחר עובד להזנת אילוצים:</label>
                        <select id="empSelect" onchange="renderConstraints()" class="w-full bg-white border border-slate-300 text-slate-900 text-sm rounded-xl focus:ring-primary-500 focus:border-primary-500 block p-3 shadow-sm transition">
                            <option value="" disabled selected>-- בחר עובד --</option>
                        </select>
                    </div>

                    <div class="flex items-center gap-4 bg-white p-2 rounded-xl shadow-sm border border-slate-200">
                        <button onclick="changeConstraintsWeek(-1)" class="p-2 hover:bg-slate-100 rounded-lg transition text-slate-600">
                            <i data-lucide="chevron-right" class="w-5 h-5"></i>
                        </button>
                        <div class="text-center min-w-[200px]">
                            <span class="block text-sm text-slate-500">שבוע נוכחי</span>
                            <span id="constraintsWeekLabel" class="font-bold text-slate-800"></span>
                        </div>
                        <button onclick="changeConstraintsWeek(1)" class="p-2 hover:bg-slate-100 rounded-lg transition text-slate-600">
                            <i data-lucide="chevron-left" class="w-5 h-5"></i>
                        </button>
                    </div>
                </div>

                <div id="noEmpSelected" class="text-center py-16 text-slate-400">
                    <i data-lucide="user-search" class="w-16 h-16 mx-auto mb-4 opacity-50"></i>
                    <p class="text-lg">אנא בחר איש צוות כדי לצפות ולהזין אילוצים.</p>
                </div>

                <div id="constraintsArea" class="hidden">
                    <p class="text-slate-600 mb-6 flex items-center gap-2">
                        <i data-lucide="info" class="w-4 h-4 text-primary-500"></i>
                        סמן את המשמרות בהן <span class="font-bold text-red-500">לא ניתן</span> לעבוד השבוע:
                    </p>
                    
                    <div id="constraintsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-7 gap-4">
                        <!-- יוצר דינמית -->
                    </div>
                </div>

            </div>
        </section>

        <!-- תצוגה 2: שיבוץ שבועי -->
        <section id="view-schedule" class="hidden animate-fade-in">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 md:p-8">
                
                <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
                    <div class="flex items-center gap-4 bg-slate-50 p-2 rounded-xl border border-slate-200">
                        <button onclick="changeScheduleWeek(-1)" class="p-2 hover:bg-white rounded-lg shadow-sm transition text-slate-600 border border-transparent hover:border-slate-200">
                            <i data-lucide="chevron-right" class="w-5 h-5"></i>
                        </button>
                        <div class="text-center min-w-[220px]">
                            <h2 class="font-bold text-lg text-slate-800" id="scheduleWeekLabel"></h2>
                        </div>
                        <button onclick="changeScheduleWeek(1)" class="p-2 hover:bg-white rounded-lg shadow-sm transition text-slate-600 border border-transparent hover:border-slate-200">
                            <i data-lucide="chevron-left" class="w-5 h-5"></i>
                        </button>
                    </div>

                    <div class="flex gap-4 text-sm bg-slate-50 px-4 py-2 rounded-xl border border-slate-200">
                        <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-red-400"></span> התנגשות אילוץ</span>
                        <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-emerald-400"></span> שובץ</span>
                    </div>
                </div>

                <div class="overflow-x-auto rounded-xl border border-slate-200 shadow-sm">
                    <table class="w-full text-right text-sm">
                        <thead class="bg-slate-50 text-slate-700 border-b border-slate-200" id="scheduleThead">
                            <!-- יוצר דינמית -->
                        </thead>
                        <tbody id="scheduleTbody" class="divide-y divide-slate-100">
                            <!-- יוצר דינמית -->
                        </tbody>
                    </table>
                </div>

            </div>
        </section>

        <!-- תצוגה 3: לוח שנה חודשי -->
        <section id="view-calendar" class="hidden animate-fade-in">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 md:p-8">
                
                <div class="flex justify-between items-center mb-8 bg-slate-50 p-3 rounded-xl border border-slate-200">
                    <button onclick="changeCalendarMonth(-1)" class="flex items-center gap-2 px-4 py-2 hover:bg-white rounded-lg shadow-sm transition text-slate-700 border border-transparent hover:border-slate-200">
                        <i data-lucide="chevron-right" class="w-4 h-4"></i> חודש קודם
                    </button>
                    <h2 class="text-xl font-bold text-slate-800" id="calendarMonthLabel"></h2>
                    <button onclick="changeCalendarMonth(1)" class="flex items-center gap-2 px-4 py-2 hover:bg-white rounded-lg shadow-sm transition text-slate-700 border border-transparent hover:border-slate-200">
                        חודש הבא <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    </button>
                </div>

                <div class="grid grid-cols-7 gap-px bg-slate-200 border border-slate-200 rounded-xl overflow-hidden shadow-sm" id="calendarGrid">
                    <!-- כותרות ימים -->
                    <div class="bg-slate-50 py-3 text-center font-semibold text-slate-700">ראשון</div>
                    <div class="bg-slate-50 py-3 text-center font-semibold text-slate-700">שני</div>
                    <div class="bg-slate-50 py-3 text-center font-semibold text-slate-700">שלישי</div>
                    <div class="bg-slate-50 py-3 text-center font-semibold text-slate-700">רביעי</div>
                    <div class="bg-slate-50 py-3 text-center font-semibold text-slate-700">חמישי</div>
                    <div class="bg-slate-50 py-3 text-center font-semibold text-slate-700">שישי</div>
                    <div class="bg-slate-50 py-3 text-center font-semibold text-slate-700">שבת</div>
                    
                    <!-- תאים ייוצרו דינמית -->
                </div>

            </div>
        </section>

    </div>

    <!-- מודאל מחיקת נתונים -->
    <div id="clearDataModal" class="fixed inset-0 bg-slate-900/50 hidden flex items-center justify-center z-50 transition-opacity opacity-0">
        <div class="bg-white rounded-2xl shadow-xl p-8 max-w-md w-full mx-4 transform scale-95 transition-transform duration-300" id="clearDataModalContent">
            <div class="w-12 h-12 bg-red-100 text-red-600 rounded-full flex items-center justify-center mx-auto mb-4">
                <i data-lucide="alert-triangle" class="w-6 h-6"></i>
            </div>
            <h3 class="text-xl font-bold text-center text-slate-900 mb-2">איפוס מערכת</h3>
            <p class="text-slate-500 text-center mb-8">האם אתה בטוח שברצונך למחוק את כל האילוצים והשיבוצים? הפעולה מוחקת את כל ההיסטוריה ולא ניתנת לביטול.</p>
            <div class="flex gap-4">
                <button onclick="hideClearDataModal()" class="flex-1 px-4 py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-xl font-medium transition">ביטול</button>
                <button onclick="executeClearData()" class="flex-1 px-4 py-3 bg-red-600 hover:bg-red-700 text-white rounded-xl font-medium transition shadow-sm">כן, מחק הכל</button>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-6 right-6 bg-slate-900 text-white px-6 py-4 rounded-xl shadow-2xl flex items-center gap-3 z-50 hidden transition-all duration-300 transform translate-y-full opacity-0">
        <i data-lucide="check-circle-2" class="w-5 h-5 text-emerald-400"></i>
        <span id="toastMsg" class="font-medium"></span>
    </div>

    <script>
        // --- Data & Constants ---
        const employees = ['שירה', 'בר', 'שי', 'מיקה', 'אגם', 'עמוס', 'יצחק', 'עומר', 'יובל', 'מיכאל'];
        
        const shifts = [
            { id: 'morning', name: 'בוקר', time: '07:00-15:00', icon: 'sunrise' },
            { id: 'afternoon', name: 'צהריים', time: '15:00-23:00', icon: 'sun' },
            { id: 'night', name: 'לילה', time: '23:00-07:00', icon: 'moon' }
        ];
        
        const dayNames = ['ראשון', 'שני', 'שלישי', 'רביעי', 'חמישי', 'שישי', 'שבת'];
        const monthNames = ['ינואר', 'פברואר', 'מרץ', 'אפריל', 'מאי', 'יוני', 'יולי', 'אוגוסט', 'ספטמבר', 'אוקטובר', 'נובמבר', 'דצמבר'];

        // --- State ---
        let db = { constraints: {}, schedule: {} };
        let currentConstraintsDate = new Date();
        let currentScheduleDate = new Date();
        let currentCalendarDate = new Date();

        // --- Init ---
        function init() {
            // התקנת אייקונים
            lucide.createIcons();

            // טעינת נתונים
            const saved = localStorage.getItem('shift_manager_pro');
            if (saved) db = JSON.parse(saved);

            // אתחול תאריכים לתחילת השבוע (יום ראשון)
            currentConstraintsDate = getStartOfWeek(new Date());
            currentScheduleDate = getStartOfWeek(new Date());
            
            // תאריך ללוח שנה (ראשון בחודש)
            currentCalendarDate = new Date(new Date().getFullYear(), new Date().getMonth(), 1);

            populateEmployees();
            updateAllViews();
        }

        // --- Utils ---
        function getStartOfWeek(date) {
            const d = new Date(date);
            const day = d.getDay();
            const diff = d.getDate() - day;
            return new Date(d.getFullYear(), d.getMonth(), diff);
        }

        function formatDateKey(date) {
            const d = new Date(date);
            const year = d.getFullYear();
            const month = String(d.getMonth() + 1).padStart(2, '0');
            const day = String(d.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function formatDateDisplay(date) {
            return `${String(date.getDate()).padStart(2, '0')}/${String(date.getMonth() + 1).padStart(2, '0')}`;
        }

        function saveData() {
            localStorage.setItem('shift_manager_pro', JSON.stringify(db));
        }

        function showToast(msg) {
            const toast = document.getElementById('toast');
            document.getElementById('toastMsg').textContent = msg;
            toast.classList.remove('hidden');
            
            // Trigger animation
            setTimeout(() => {
                toast.classList.remove('translate-y-full', 'opacity-0');
            }, 10);

            setTimeout(() => {
                toast.classList.add('translate-y-full', 'opacity-0');
                setTimeout(() => toast.classList.add('hidden'), 300);
            }, 3000);
        }

        // --- UI Navigation ---
        function switchTab(tabId) {
            ['constraints', 'schedule', 'calendar'].forEach(t => {
                document.getElementById(`tab-${t}`).className = 'tab-btn tab-inactive pb-4 px-2 text-lg flex items-center gap-2 whitespace-nowrap';
                document.getElementById(`view-${t}`).classList.add('hidden');
            });
            
            document.getElementById(`tab-${tabId}`).className = 'tab-btn tab-active pb-4 px-2 text-lg flex items-center gap-2 whitespace-nowrap';
            document.getElementById(`view-${tabId}`).classList.remove('hidden');

            updateAllViews();
        }

        function updateAllViews() {
            if (!document.getElementById('view-constraints').classList.contains('hidden')) renderConstraints();
            if (!document.getElementById('view-schedule').classList.contains('hidden')) renderSchedule();
            if (!document.getElementById('view-calendar').classList.contains('hidden')) renderCalendar();
            lucide.createIcons(); // רענון אייקונים לאלמנטים שנוצרו דינמית
        }

        // --- Constraints Logic ---
        function populateEmployees() {
            const select = document.getElementById('empSelect');
            employees.forEach(emp => {
                const opt = document.createElement('option');
                opt.value = emp;
                opt.textContent = emp;
                select.appendChild(opt);
            });
        }

        function changeConstraintsWeek(offset) {
            currentConstraintsDate.setDate(currentConstraintsDate.getDate() + (offset * 7));
            renderConstraints();
            lucide.createIcons();
        }

        function renderConstraints() {
            const emp = document.getElementById('empSelect').value;
            const noEmp = document.getElementById('noEmpSelected');
            const area = document.getElementById('constraintsArea');
            const grid = document.getElementById('constraintsGrid');
            const label = document.getElementById('constraintsWeekLabel');

            // כותרת תאריכים
            const endOfWeek = new Date(currentConstraintsDate);
            endOfWeek.setDate(endOfWeek.getDate() + 6);
            label.textContent = `${formatDateDisplay(currentConstraintsDate)} - ${formatDateDisplay(endOfWeek)}`;

            if (!emp) {
                noEmp.classList.remove('hidden');
                area.classList.add('hidden');
                return;
            }

            noEmp.classList.add('hidden');
            area.classList.remove('hidden');
            grid.innerHTML = '';

            const empConstraints = db.constraints[emp] || [];

            for (let i = 0; i < 7; i++) {
                const currentDate = new Date(currentConstraintsDate);
                currentDate.setDate(currentDate.getDate() + i);
                const dateKey = formatDateKey(currentDate);

                const dayCard = document.createElement('div');
                dayCard.className =
